rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Optimized gallery images are public; only the pipeline writes them.
    match /galleries/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
